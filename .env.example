# Required: OpenRouter API key (used for both skill invocation and LLM judge)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: Override the default skill invocation model
# BENCH_SKILL_MODEL=anthropic/claude-sonnet-4-6

# Optional: Override the default judge model
# BENCH_JUDGE_MODEL=anthropic/claude-opus-4-6

# Optional: Path to secret scenarios directory (for CI)
# CRYPTO_BENCH_SECRET_DIR=./scenarios/secret
